{
  "name": "trendforge",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first AI trend video workstation.",
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --parallel --filter @trendforge/server --filter @trendforge/web dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "prisma:generate": "pnpm --filter @trendforge/server prisma:generate",
    "prisma:migrate": "pnpm --filter @trendforge/server prisma:migrate",
    "prisma:studio": "pnpm --filter @trendforge/server prisma:studio"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "concurrently": "^9.1.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.33.0"
}
