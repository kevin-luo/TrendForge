{
  "name": "@trendforge/server",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run --passWithNoTests",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "tsx src/prisma-cli.ts migrate",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/multipart": "^9.0.3",
    "@fastify/static": "^8.0.2",
    "@prisma/client": "6.1.0",
    "@trendforge/connectors": "workspace:*",
    "@trendforge/core": "workspace:*",
    "@trendforge/ffmpeg": "workspace:*",
    "@trendforge/llm": "workspace:*",
    "@trendforge/renderer": "workspace:*",
    "@trendforge/subtitles": "workspace:*",
    "@trendforge/templates": "workspace:*",
    "@trendforge/tts": "workspace:*",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "prisma": "6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  }
}
