{
  "name": "@trendforge/renderer",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run --passWithNoTests",
    "render:html": "tsx src/cli.ts"
  },
  "dependencies": {
    "@trendforge/core": "workspace:*",
    "@trendforge/templates": "workspace:*",
    "fastify": "^5.2.0",
    "hyperframes": "^0.4.44",
    "puppeteer-core": "^25.1.0"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
